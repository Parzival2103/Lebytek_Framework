# =============================================
# ENTORNO DE APLICACIÓN
# =============================================
APP_ENV=local
APP_DEBUG=true
APP_NAME="Sistema Administrativo"
# Producción (document root = public/): https://tudominio.com sin /public
APP_URL=http://localhost:8000/
APP_KEY=cambiar_por_clave_aleatoria_de_32_chars
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es

# =============================================
# BASE DE DATOS
# =============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=contraste_db
DB_USERNAME=root
DB_PASSWORD=

# =============================================
# SESIÓN
# =============================================
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# =============================================
# ALMACENAMIENTO
# =============================================
STORAGE_PATH=storage
MAX_UPLOAD_MB=10

# =============================================
# CORREO (para notificaciones futuras)
# =============================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@empresa.com
MAIL_FROM_NAME="Sistema Administrativo"

# =============================================
# SEGURIDAD
# =============================================
BCRYPT_ROUNDS=12
CSRF_TOKEN_LENGTH=32
