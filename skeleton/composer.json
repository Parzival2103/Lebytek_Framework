{
    "name": "lebytek/skeleton",
    "description": "Esqueleto de aplicacion Lebytek (consume lebytek/framework)",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "lebytek/framework": "^1.0"
    },
    "repositories": [
        { "type": "vcs", "url": "https://github.com/Parzival2103/Lebytek_Framework" }
    ],
    "autoload": {
        "psr-4": { "App\\": "app/" }
    },
    "config": { "sort-packages": true }
}
