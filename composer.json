{
    "name": "lebytek/framework",
    "description": "Lebytek Framework — plataforma PHP + back-office lebytek.com (monorepo)",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "^3.1",
        "phpmailer/phpmailer": "^7.1"
    },
    "autoload": {
        "psr-4": {
            "Lebytek\\Framework\\": "src/",
            "App\\": "app/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
