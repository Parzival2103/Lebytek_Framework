{
  "resource": {
    "key": "demo_productos",
    "title": "Demo Productos",
    "table": "dom_demo_productos",
    "primary_key": "id",
    "permission_prefix": "demo_productos"
  },
  "security": {
    "allow_core_table": false,
    "mode": "restricted"
  },
  "states": {
    "column": "status",
    "values": {
      "activo":   { "label": "Activo",   "badge": "success" },
      "inactivo": { "label": "Inactivo", "badge": "secondary" }
    },
    "transitions": {
      "activo":   ["inactivo"],
      "inactivo": ["activo"]
    }
  },
  "list": {
    "group_by": "status",
    "aggregation": {
      "enabled": true,
      "max_rows": 5000,
      "require_filter_above": 5000
    },
    "table_compact": false,
    "columns": [
      {
        "name": "id",
        "label": "ID",
        "sortable": true
      },
      {
        "name": "codigo",
        "label": "Código",
        "searchable": true,
        "sortable": true
      },
      {
        "name": "nombre",
        "label": "Nombre",
        "searchable": true,
        "sortable": true
      },
      {
        "name": "precio_venta",
        "label": "Precio",
        "format": "money",
        "sortable": true
      },
      {
        "name": "stock_actual",
        "label": "Stock",
        "sortable": true
      },
      {
        "name": "status",
        "label": "Estado",
        "badge": {
          "activo": "success",
          "inactivo": "secondary"
        }
      }
    ],
    "filters": [
      {
        "field": "status",
        "label": "Estado"
      }
    ],
    
    "summaries": [
      {
        "column": "precio_venta",
        "type": "sum",
        "format": "money",
        "label": "Suma precio"
      },
      {
        "column": "stock_actual",
        "type": "sum",
        "format": "money",
        "label": "Suma stock"
      }
    ],
    "actions": ["show", "edit", "delete"]
  },
  "actions": {
    "row": [
      { "name": "show", "type": "builtin" },
      { "name": "edit", "type": "builtin" },
      { "name": "delete", "type": "builtin" },
      { "name": "toggle", "type": "handler", "handler": "demo_producto_toggle",
        "label": "Alternar estado", "icon": "bi-toggle-on", "method": "POST",
        "permission": "editar", "confirm": "¿Cambiar el estado de este producto?" },
      { "name": "desactivar", "type": "transition", "to": "inactivo",
        "label": "Desactivar", "icon": "bi-pause-circle", "method": "POST",
        "permission": "editar", "confirm": "¿Desactivar este producto?",
        "visible_when": { "status": "activo" } },
      { "name": "activar", "type": "transition", "to": "activo",
        "label": "Activar", "icon": "bi-play-circle", "method": "POST",
        "permission": "editar", "confirm": "¿Activar este producto?",
        "visible_when": { "status": "inactivo" }, "guard": "demo_producto_state_guard" }
    ],
    "bulk": [
      { "name": "toggle", "type": "handler", "handler": "demo_producto_toggle",
        "label": "Alternar estado", "permission": "editar", "confirm": "¿Alternar el estado de los seleccionados?" }
    ]
  },
  "form": {
    "fields": [
      {
        "name": "codigo",
        "label": "Código",
        "type": "text",
        "required": true,
        "col": "col-md-4"
      },
      {
        "name": "nombre",
        "label": "Nombre",
        "type": "text",
        "required": true,
        "col": "col-md-8"
      },
      {
        "name": "precio_venta",
        "label": "Precio de venta",
        "type": "text",
        "required": true,
        "col": "col-md-4",
        "validation": {
          "type": "decimal",
          "min": 0
        },
        "help_text": "Use punto o coma como separador decimal (ej. 19.99 o 19,99)."
      },
      {
        "name": "stock_actual",
        "label": "Stock actual",
        "type": "text",
        "required": true,
        "col": "col-md-4",
        "validation": {
          "type": "integer",
          "min": 0
        }
      },
      {
        "name": "status",
        "label": "Estado",
        "type": "select",
        "required": true,
        "options": {
          "activo": "Activo",
          "inactivo": "Inactivo"
        },
        "default": "activo",
        "col": "col-md-4"
      }
    ]
  },
  "uploads": {
    "enabled": false,
    "public_path": "uploads/cruds/demo_productos"
  },
  "hooks": {
    "handler": null
  }
}
