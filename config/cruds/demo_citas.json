{
  "resource": {
    "key": "demo_citas",
    "title": "Demo Citas",
    "table": "dom_demo_citas",
    "primary_key": "id",
    "permission_prefix": "demo_citas"
  },
  "security": {
    "allow_core_table": false,
    "mode": "restricted"
  },
  "states": {
    "column": "estado",
    "values": {
      "pendiente":  { "label": "Pendiente",  "badge": "warning" },
      "confirmada": { "label": "Confirmada", "badge": "success" },
      "cancelada":  { "label": "Cancelada",  "badge": "secondary" }
    },
    "transitions": {
      "pendiente":  ["confirmada", "cancelada"],
      "confirmada": ["cancelada"],
      "cancelada":  ["pendiente"]
    }
  },
  "detail": {
    "tabs": [
      { "key": "general", "label": "Datos generales", "type": "fields", "columns": ["cliente", "servicio", "estado", "fecha_inicio", "fecha_fin"] },
      { "key": "historial", "label": "Historial", "type": "history" }
    ]
  },
  "list": {
    "group_by": "",
    "aggregation": {
      "enabled": true,
      "max_rows": 5000,
      "require_filter_above": 5000
    },
    "table_compact": false,
    "columns": [
      { "name": "id", "label": "ID", "sortable": true },
      { "name": "cliente", "label": "Cliente", "searchable": true, "sortable": true },
      { "name": "servicio", "label": "Servicio", "searchable": true, "sortable": true },
      { "name": "fecha_inicio", "label": "Inicio", "format": "datetime", "sortable": true },
      { "name": "fecha_fin", "label": "Fin", "format": "datetime", "sortable": true },
      {
        "name": "estado",
        "label": "Estado",
        "badge": {
          "pendiente": "warning",
          "confirmada": "success",
          "cancelada": "secondary"
        }
      }
    ],
    "filters": [
      { "field": "estado", "label": "Estado" }
    ],
    "summaries": [],
    "actions": ["show", "edit", "delete"]
  },
  "actions": {
    "row": [
      { "name": "show", "type": "builtin" },
      { "name": "edit", "type": "builtin" },
      { "name": "delete", "type": "builtin" },
      { "name": "confirmar", "type": "transition", "to": "confirmada",
        "label": "Confirmar", "icon": "bi-check-circle", "method": "POST",
        "permission": "editar", "confirm": "¿Confirmar esta cita?",
        "visible_when": { "estado": "pendiente" } },
      { "name": "cancelar", "type": "transition", "to": "cancelada",
        "label": "Cancelar", "icon": "bi-x-circle", "method": "POST",
        "permission": "editar", "confirm": "¿Cancelar esta cita?",
        "visible_when": { "estado": "pendiente" } }
    ],
    "bulk": []
  },
  "form": {
    "fields": [
      {
        "name": "cliente",
        "label": "Cliente",
        "type": "text",
        "required": true,
        "col": "col-md-6",
        "validation": { "maxlength": 120 }
      },
      {
        "name": "servicio",
        "label": "Servicio",
        "type": "text",
        "required": true,
        "col": "col-md-6",
        "validation": { "maxlength": 120 }
      },
      {
        "name": "fecha_inicio",
        "label": "Fecha y hora de inicio",
        "type": "datetime-local",
        "required": true,
        "col": "col-md-6"
      },
      {
        "name": "fecha_fin",
        "label": "Fecha y hora de fin",
        "type": "datetime-local",
        "required": false,
        "col": "col-md-6"
      },
      {
        "name": "estado",
        "label": "Estado",
        "type": "select",
        "required": true,
        "options": {
          "pendiente": "Pendiente",
          "confirmada": "Confirmada",
          "cancelada": "Cancelada"
        },
        "default": "pendiente",
        "col": "col-md-6"
      }
    ]
  },
  "uploads": {
    "enabled": false,
    "public_path": "uploads/cruds/demo_citas"
  },
  "hooks": {
    "handler": null
  }
}
