# =============================================
# ENTORNO DE APLICACIÓN
# =============================================
APP_ENV=local
APP_DEBUG=true
APP_NAME="Sistema Administrativo"
# URL base pública (sin barra final). Debe coincidir con cómo accedes al sitio.
# Producción: con document root en public/, usar https://tudominio.com (nunca .../public).
# Local: p. ej. http://localhost:8000 si corres: php -S localhost:8000 -t public
APP_URL=http://localhost:8000
APP_KEY=cambiar_por_clave_aleatoria_de_32_chars
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es

# =============================================
# BASE DE DATOS
# =============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=contraste_db
DB_USERNAME=root
DB_PASSWORD=

# =============================================
# SESIÓN
# =============================================
SESSION_LIFETIME=120
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# =============================================
# ALMACENAMIENTO
# =============================================
STORAGE_PATH=storage
MAX_UPLOAD_MB=10

# =============================================
# CORREO (para notificaciones futuras)
# =============================================
# MAIL_DRIVER: smtp | log (log escribe el correo a storage/logs — usar en desarrollo)
MAIL_DRIVER=log
MAIL_HOST=mail.tudominio.com
MAIL_PORT=465
# MAIL_ENCRYPTION: ssl (465/SMTPS) | tls (587/STARTTLS). Vacío = auto por puerto.
MAIL_ENCRYPTION=ssl
MAIL_TIMEOUT=15
MAIL_USERNAME=cuenta@tudominio.com
MAIL_PASSWORD=
# Debe coincidir con MAIL_USERNAME en la mayoría de hostings compartidos.
MAIL_FROM_ADDRESS=cuenta@tudominio.com
MAIL_FROM_NAME="Sistema Administrativo"

# Registro público de usuarios (requiere correo verificado). Apagado por defecto.
REGISTRO_HABILITADO=false

# Rate limiting login (fallos por IP o email en ventana)
LOGIN_MAX_INTENTOS=5
LOGIN_VENTANA_MIN=15

# =============================================
# SEGURIDAD
# =============================================
BCRYPT_ROUNDS=12
CSRF_TOKEN_LENGTH=32
