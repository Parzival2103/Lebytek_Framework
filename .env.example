# =============================================
# ENTORNO DE APLICACIÓN
# =============================================
APP_ENV=local
APP_DEBUG=true
APP_NAME="Lebytek"
# URL base pública (sin barra final). Debe coincidir con cómo accedes al sitio.
# Producción: document root en public/ → https://lebytek.com (nunca .../public).
# Local: p. ej. http://localhost:8000 si corres: php -S localhost:8000 -t public
APP_URL=http://localhost:8000
APP_KEY=cambiar_por_clave_aleatoria_de_32_chars
APP_TIMEZONE=America/Mexico_City
APP_LOCALE=es
APP_ASSET_VERSION=1

# =============================================
# BASE DE DATOS
# =============================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lebytek_db
DB_USERNAME=root
DB_PASSWORD=

# =============================================
# SESIÓN
# =============================================
SESSION_LIFETIME=120
SESSION_REMEMBER_LIFETIME=43200
SESSION_SECURE=false
SESSION_HTTP_ONLY=true

# =============================================
# ALMACENAMIENTO
# =============================================
STORAGE_PATH=storage
MAX_UPLOAD_MB=10

# =============================================
# CORREO
# =============================================
MAIL_DRIVER=log
MAIL_HOST=mail.tudominio.com
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_TIMEOUT=15
MAIL_USERNAME=cuenta@tudominio.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=cuenta@tudominio.com
MAIL_FROM_NAME="Lebytek"

REGISTRO_HABILITADO=false
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_MAX_INTENTOS=5
LOGIN_VENTANA_MIN=15

# =============================================
# SEGURIDAD
# =============================================
BCRYPT_ROUNDS=12
CSRF_TOKEN_LENGTH=32

# =============================================
# API MOTOR — api.lebytek.com (token de plataforma)
# =============================================
# Contrato: docs/integration/waapi-api-contract.md
# Emitir token en VPS api: php artisan integration:issue-waapi-token --revoke
LEBYTEK_API_URL=https://api.lebytek.com/api/v1
LEBYTEK_API_TOKEN=
LEBYTEK_API_TIMEOUT=30
LEBYTEK_API_RETRY_MAX=3
LEBYTEK_API_RETRY_DELAY_MS=500

# ── Integraciones locales (legacy / demo; Fase 2 usa api) ──
GREEN_API_ENABLED=false
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_INSTANCE=
GREEN_API_TOKEN=
GREEN_API_TIMEOUT=15
GREEN_API_WEBHOOK_TOKEN=
GREEN_API_PARTNER_TOKEN=
INTEGRATIONS_API_DOCS_URL=/docs/integraciones/whatsapp-api
